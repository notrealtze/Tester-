local RunService = game:GetService("RunService")
local Players    = game:GetService("Players")
local lp         = Players.LocalPlayer

local warpInput  = nil
local warpLoaded = false
task.spawn(function()
	local ok, res = pcall(function()
		return require(game:GetService("ReplicatedStorage").Modules.Warp).Client("Input")
	end)
	if ok and res then
		warpInput  = res
		warpLoaded = true
	end
end)

local function getKillerFolder()
	local pf = workspace:FindFirstChild("PLAYERS")
	return pf and pf:FindFirstChild("KILLER")
end

local function getKillerPart()
	local kf = getKillerFolder()
	if not kf then return nil end
	for _, model in ipairs(kf:GetChildren()) do
		if model:IsA("Model") then
			local root = model:FindFirstChild("RootPart")
				or model:FindFirstChild("HumanoidRootPart")
				or model.PrimaryPart
			if root then return root end
		end
	end
end

local function getKillerAnimator()
	local kf = getKillerFolder()
	if not kf then return nil end
	for _, model in ipairs(kf:GetChildren()) do
		if model:IsA("Model") then
			local hum  = model:FindFirstChildOfClass("Humanoid")
			local anim = model:FindFirstChildOfClass("Animator")
				or (hum and hum:FindFirstChildOfClass("Animator"))
			if anim then return anim end
		end
	end
end

local function tryParry()
	if not warpLoaded or not warpInput then return end
	pcall(function() warpInput:Fire(true, {"Ability", 2}) end)
end

local function fireParry()
	local cfg        = getgenv().BestAutoParry["AutoParry"]
	if not cfg.Enabled then return end
	local char       = lp.Character
	local hrp        = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local killerPart = getKillerPart()
	if not killerPart then return end
	if (killerPart.Position - hrp.Position).Magnitude > cfg.Distance then return end
	if cfg.KillerAngle > 0 then
		local toSurvivor = (hrp.Position - killerPart.Position) * Vector3.new(1, 0, 1)
		local killerLook = killerPart.CFrame.LookVector * Vector3.new(1, 0, 1)
		local angle = math.deg(math.acos(math.clamp(toSurvivor.Unit:Dot(killerLook.Unit), -1, 1)))
		if angle > cfg.KillerAngle / 2 then return end
	end
	if cfg.SurvivorAngle > 0 then
		local toKiller     = (killerPart.Position - hrp.Position) * Vector3.new(1, 0, 1)
		local survivorLook = hrp.CFrame.LookVector * Vector3.new(1, 0, 1)
		local angle = math.deg(math.acos(math.clamp(toKiller.Unit:Dot(survivorLook.Unit), -1, 1)))
		if angle > cfg.SurvivorAngle / 2 then return end
	end
	tryParry()
end

local attackCache = {}
local pendingCache = {}

local function cacheAnim(animId, onConfirmed)
	if attackCache[animId] == true then
		if onConfirmed then onConfirmed() end
		return
	end
	if attackCache[animId] == false then
		return
	end
	if pendingCache[animId] then
		if onConfirmed then
			local existing = pendingCache[animId]
			pendingCache[animId] = function()
				existing()
				onConfirmed()
			end
		end
		return
	end

	attackCache[animId] = nil
	pendingCache[animId] = onConfirmed or function() end

	task.spawn(function()
		local ok, kfs = pcall(function()
			return game:GetService("KeyframeSequenceProvider"):GetKeyframeSequenceAsync(animId)
		end)
		local isAttack = false
		if ok and kfs then
			for _, kf in ipairs(kfs:GetKeyframes()) do
				for _, marker in ipairs(kf:GetMarkers()) do
					if marker.Name == "SwingStart" then
						isAttack = true
						break
					end
				end
				if isAttack then break end
			end
		end
		attackCache[animId] = isAttack
		local cb = pendingCache[animId]
		pendingCache[animId] = nil
		if isAttack and cb then
			cb()
		end
	end)
end

local parryConns  = {}
local markerConns = {}
getgenv().BestAutoParry._parryConns  = parryConns
getgenv().BestAutoParry._markerConns = markerConns

local function clearMarkerConns()
	for _, c in ipairs(markerConns) do pcall(function() c:Disconnect() end) end
	table.clear(markerConns)
end

local function clearParryConns()
	for _, c in ipairs(parryConns) do pcall(function() c:Disconnect() end) end
	table.clear(parryConns)
	clearMarkerConns()
end

local function hookAnim(anim)
	clearMarkerConns()
	for _, track in ipairs(anim:GetPlayingAnimationTracks()) do
		cacheAnim(track.Animation.AnimationId)
	end
	local c = anim.AnimationPlayed:Connect(function(track)
		local animId = track.Animation.AnimationId
		cacheAnim(animId, function()
			fireParry()
		end)
	end)
	table.insert(markerConns, c)
end

local function startParry()
	clearParryConns()
	local anim = getKillerAnimator()
	if anim then hookAnim(anim) end
	local kf = getKillerFolder()
	if kf then
		local ca = kf.ChildAdded:Connect(function()
			task.wait(0.5)
			local a = getKillerAnimator()
			if a then hookAnim(a) end
		end)
		table.insert(parryConns, ca)
	end
end

local function watchKillerForCache()
	task.spawn(function()
		while true do
			local anim = getKillerAnimator()
			if anim then
				for _, track in ipairs(anim:GetPlayingAnimationTracks()) do
					cacheAnim(track.Animation.AnimationId)
				end
				anim.AnimationPlayed:Connect(function(track)
					cacheAnim(track.Animation.AnimationId)
				end)
				return
			end
			task.wait(0.5)
		end
	end)
end

watchKillerForCache()

workspace.DescendantAdded:Connect(function(obj)
	if obj.Name == "KILLER" then
		task.wait(0.5)
		watchKillerForCache()
	end
end)

local staminaConn

local function startStamina()
	if staminaConn then staminaConn:Disconnect(); staminaConn = nil end
	staminaConn = RunService.Heartbeat:Connect(function()
		getgenv().BestAutoParry._staminaConn = staminaConn
		local cfg = getgenv().BestAutoParry["InfStamina"]
		if not cfg.Enabled then return end
		local c = lp.Character
		if not c then return end
		local mx = c:GetAttribute("MaxStamina") or 100
		local st = c:GetAttribute("Stamina")
		if st == nil then return end
		if st <= cfg.Threshold then
			if cfg.Delay > 0 then task.wait(cfg.Delay) end
			c:SetAttribute("Stamina", mx)
		end
	end)
end

lp.CharacterAdded:Connect(function()
	task.wait(1)
	if getgenv().BestAutoParry["InfStamina"].Enabled then startStamina() end
	if getgenv().BestAutoParry["AutoParry"].Enabled then startParry() end
end)

startStamina()
startParry()

local ringPart = Instance.new("Part")
ringPart.Name         = "BestAutoParryRing"
ringPart.Anchored     = true
ringPart.CanCollide   = false
ringPart.CanQuery     = false
ringPart.CanTouch     = false
ringPart.CastShadow   = false
ringPart.Shape        = Enum.PartType.Cylinder
ringPart.Material     = Enum.Material.ForceField
ringPart.Color        = Color3.fromRGB(0, 100, 255)
ringPart.Transparency = 0.6
ringPart.Size         = Vector3.new(0.099, 1, 1)
ringPart.Parent       = workspace
getgenv().BestAutoParry._ring = ringPart

RunService.Heartbeat:Connect(function()
	local cfg  = getgenv().BestAutoParry["AutoParry"]
	local char = lp.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	if not cfg.Enabled or not hrp then
		ringPart.Size = Vector3.new(0, 0.099, 0)
		return
	end
	local d        = cfg.Distance * 2
	local origin   = hrp.Position
	local rp       = RaycastParams.new()
	local excluded = {ringPart}
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character then table.insert(excluded, p.Character) end
	end
	rp.FilterDescendantsInstances = excluded
	rp.FilterType = Enum.RaycastFilterType.Exclude
	local ray = workspace:Raycast(origin, Vector3.new(0, -50, 0), rp)
	ringPart.Size   = Vector3.new(0.099, d, d)
	ringPart.CFrame = CFrame.new(origin.X, ray.Position.Y, origin.Z) * CFrame.Angles(0, 0, -1.5708)
end)

